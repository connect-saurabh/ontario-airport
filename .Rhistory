sd = value_per_passenger_sd
)
sim_engagements <- max(0, sim_engagements)
sim_impressions <- max(0, sim_impressions)
sim_posts <- max(0, sim_posts)
sim_value_per_passenger <- max(0, sim_value_per_passenger)
baseline_row <- data.frame(
total_engagements = baseline_inputs$mean_engagements,
total_impressions = baseline_inputs$mean_impressions,
total_posts = baseline_inputs$mean_posts,
time_index = mean(data_2025$time_index)
)
sim_row <- data.frame(
total_engagements = sim_engagements,
total_impressions = sim_impressions,
total_posts = sim_posts,
time_index = mean(data_2025$time_index)
)
baseline_pred <- predict(model_mc, newdata = baseline_row)
simulated_pred <- predict(model_mc, newdata = sim_row)
incremental_passengers <- simulated_pred - baseline_pred
incremental_value <- incremental_passengers * sim_value_per_passenger
roi_vs_5k_cost <- (incremental_value - 114958) / 114958
c(
baseline_pred = baseline_pred,
simulated_pred = simulated_pred,
incremental_passengers = incremental_passengers,
incremental_value = incremental_value,
roi_vs_5k_cost = roi_vs_5k_cost
)
}, simplify = TRUE)
sim_results <- as.data.frame(t(sim_results))
sim_summary <- sim_results %>%
summarise(
mean_incremental_passengers = mean(incremental_passengers, na.rm = TRUE),
p5_incremental_passengers = quantile(incremental_passengers, 0.05, na.rm = TRUE),
p95_incremental_passengers = quantile(incremental_passengers, 0.95, na.rm = TRUE),
mean_incremental_value = mean(incremental_value, na.rm = TRUE),
p5_incremental_value = quantile(incremental_value, 0.05, na.rm = TRUE),
p95_incremental_value = quantile(incremental_value, 0.95, na.rm = TRUE)
)
print(profile_monthly)
colnames(profile)
head(profile[, 1:20])
